# ===========================================
# DESENVOLVIMENTO
# ===========================================
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/database
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# PRODUÇÃO (Render)
# ===========================================
# NODE_ENV=production
# PORT=3001
# DATABASE_URL=sua_url_postgresql
# JWT_SECRET=senha_forte_minimo_32_caracteres
# JWT_EXPIRES_IN=7d
# ALLOWED_ORIGINS=https://seu-app.vercel.app
#
# IMPORTANTE:
# - Em produção, o backend DEVE ter HTTPS (Render já provê)
# - SameSite=None requer secure=true nos cookies (funciona automaticamente em produção)
# - Adicione seu domínio Vercel ao ALLOWED_ORIGINS
